<body>

    <nav>
        <a href="index.html">Начало</a>
        <a href="hero.html">Герой</a>
        <a href="manual.html" class="active">Ръководство</a>
        <a href="bestiary.html">Бестиарий</a>
        <a href="archive.html">Архив</a>
    </nav>

    <div class="container">
        <h1>Ръководство</h1>

        <div class="gallery" id="gallery">
            </div>
    </div>

    <div id="viewer">
        <div class="close-overlay" onclick="closeViewer()"></div>
        <button id="prev-btn" class="nav-btn" onclick="changeImage(-1)">&#10094;</button>
        <img id="viewer-img" src="">
        <button id="next-btn" class="nav-btn" onclick="changeImage(1)">&#10095;</button>
    </div>

    <script>
        const gallery = document.getElementById('gallery');
        const viewer = document.getElementById('viewer');
        const viewerImg = document.getElementById('viewer-img');
        
        // Масив, в който ще описваме страниците (Име на файл + Описание)
        const pages = [
            { src: '1.jpg', title: 'Корица' },
            // Ще добавяме останалите тук...
        ];

        let currentIdx = 0;

        function renderGallery() {
            gallery.innerHTML = '';
            pages.forEach((page, index) => {
                const wrapper = document.createElement('div');
                wrapper.className = 'thumbnail-wrapper';
                wrapper.onclick = () => openViewer(index);
                
                wrapper.innerHTML = `
                    <img src="${page.src}" class="thumbnail" alt="${page.title}">
                    <span class="page-number">стр. ${index + 1} - ${page.title}</span>
                `;
                gallery.appendChild(wrapper);
            });
        }

        function openViewer(index) {
            currentIdx = index;
            updateViewer();
            viewer.style.display = 'flex';
        }

        function closeViewer() {
            viewer.style.display = 'none';
        }

        function updateViewer() {
            viewerImg.src = pages[currentIdx].src;
            document.getElementById('prev-btn').style.visibility = (currentIdx === 0) ? 'hidden' : 'visible';
            document.getElementById('next-btn').style.visibility = (currentIdx === pages.length - 1) ? 'hidden' : 'visible';
        }

        function changeImage(step) {
            currentIdx += step;
            updateViewer();
        }

        window.addEventListener('keydown', (e) => {
            if (viewer.style.display === 'flex') {
                if (e.key === 'ArrowLeft') changeImage(-1);
                if (e.key === 'ArrowRight') changeImage(1);
                if (e.key === 'Escape') closeViewer();
            }
        });

        renderGallery();
    </script>
</body>
