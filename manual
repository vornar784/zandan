        }

        nav a:hover, nav a.active {
            color: #d4af37;
        }

        .container { padding: 40px 20px; }

        h1 {
            color: #fff;
            text-transform: uppercase;
            letter-spacing: 5px;
            margin-bottom: 30px;
        }

        /* ГАЛЕРИЯ - 1:1 С АРХИВА */
        .gallery {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
            gap: 20px;
