    <script>
        function setLang(lang) {
            document.querySelectorAll('[lang]').forEach(el => el.style.display = 'none');
            document.querySelectorAll(`[lang="${lang}"]`).forEach(el => el.style.display = 'block');
            
            // За бестиария - картите трябва да станат flex/grid вместо block
            document.querySelectorAll(`div[lang="${lang}"].monster-grid`).forEach(el => el.style.display = 'grid');

            document.getElementById('btn-bg').classList.toggle('active', lang === 'bg');
            document.getElementById('btn-en').classList.toggle('active', lang === 'en');
        }
    </script>
